# Environment variables for Offerings Bot
# Copy to .env and fill in (DO NOT COMMIT .env)

# Vercel deployment URL for the Heartlight Exchange
HEARTLIGHT_STORAGE_URL=https://heartlight-exchange.vercel.app/api/store

# Atlas's phone for approval messages (Signal/iMessage)
ATLAS_PHONE=+16198415588

# Optional: OpenClaw gateway for native messaging
# OPENCLAW_GATEWAY_URL=http://localhost:8080

# Optional: Log verbosity
# DEBUG=offerings-bot
